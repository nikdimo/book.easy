generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum SuggestionKind {
  PROPERTY_TYPE
  AMENITY
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SuggestionScope {
  GLOBAL
  LISTING_ONLY
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  UNPUBLISHED
  SUSPENDED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  CANCELLED_BY_ADMIN
  COMPLETED
}

enum BlockType {
  MANUAL_BLOCK
  BOOKING_HOLD
}

enum ListingMediaType {
  IMAGE
  VIDEO
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

// ─── User & Profile ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  image         String?
  name          String
  role          UserRole  @default(USER)
  isHost        Boolean   @default(false)
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile             Profile?
  properties          Property[]
  listings            Listing[]
  bookings            Booking[]
  auditLogs           AuditLog[]
  accounts            Account[]
  sessions            Session[]
  suggestions         Suggestion[] @relation("SuggestionHost")
  reviewedSuggestions Suggestion[] @relation("SuggestionReviewer")
  listingDrafts       ListingDraft[]
  listingReports         ListingReport[] @relation("ListingReportReporter")
  reviewedListingReports ListingReport[] @relation("ListingReportReviewer")

  @@index([email])
  @@index([role])
}

// ─── Auth.js (Google + magic link) ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id              String  @id @default(cuid())
  userId          String  @unique
  phone           String?
  bio             String?
  avatarUrl       String?
  hostBio         String?
  hostDisplayName String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Property & Listing ─────────────────────────────────────────────────────────

/**
 * Admin-manageable property types (e.g. "Detached House", "Row House"). Used to be a
 * Prisma enum, but that required a code migration + deploy every time a new type was
 * needed. Now a table so admins can approve host-suggested types at runtime (see
 * Suggestion below). `value` keeps the old enum's UPPER_SNAKE_CASE codes so existing
 * data/URLs/filters didn't need to change.
 */
model PropertyType {
  id        String   @id @default(cuid())
  value     String   @unique
  label     String
  /** false = not offered in pickers/filters going forward, but still valid for any
   *  property already using it (e.g. a "this listing only" suggestion approval). */
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  properties Property[]

  @@index([isActive])
}

model Property {
  id               String   @id @default(cuid())
  ownerId          String
  name             String
  propertyType     String
  propertyTypeInfo PropertyType @relation(fields: [propertyType], references: [value])
  address          String
  city             String
  area             String?
  country          String   @default("North Macedonia")
  postalCode       String?
  latitude         Float?
  longitude        Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner    User      @relation(fields: [ownerId], references: [id])
  listings Listing[]

  @@index([ownerId])
  @@index([city])
  @@index([propertyType])
}

model Listing {
  id             String        @id @default(cuid())
  propertyId     String
  hostId         String
  title          String
  slug           String        @unique
  description    String
  status         ListingStatus @default(DRAFT)
  maxGuests      Int
  bedrooms       Int
  bathrooms      Int
  beds           Int
  moderationNote String?
  /** True whenever the live content was created/edited since an admin last looked at
   *  it — drives the admin "Pending Review" queue independently of `status`, since
   *  listings are published immediately rather than gated behind approval. */
  needsReview    Boolean       @default(false)
  approvedAt     DateTime?
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  property           Property           @relation(fields: [propertyId], references: [id])
  host               User               @relation(fields: [hostId], references: [id])
  images             ListingImage[]
  amenities          ListingAmenity[]
  pricingRule        PricingRule?
  datePrices         ListingDatePrice[]
  availabilityBlocks AvailabilityBlock[]
  bookings           Booking[]
  suggestions        Suggestion[]
  reports            ListingReport[]

  @@index([hostId])
  @@index([status])
  @@index([slug])
}

/**
 * A new listing's form state, autosaved on field blur before it satisfies the strict
 * validation a real Listing/Property row requires (title length, required fields,
 * etc.) — so it can hold partial/incomplete data without needing those columns to be
 * nullable. Submitting for review validates this data in full, creates the real
 * Property/Listing/PricingRule rows from it, and deletes this row. Never surfaced
 * publicly — purely a host-side "resume where I left off" mechanism.
 */
model ListingDraft {
  id        String   @id @default(cuid())
  hostId    String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  host User @relation(fields: [hostId], references: [id], onDelete: Cascade)

  @@index([hostId])
}

model ListingImage {
  id           String  @id @default(cuid())
  listingId    String
  url          String
  mediaType    ListingMediaType @default(IMAGE)
  alt          String?
  displayOrder Int     @default(0)
  isPrimary    Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// ─── Amenities ──────────────────────────────────────────────────────────────────

model Amenity {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  icon      String?
  /** false = not offered in the general amenity picker, but still valid for any
   *  listing already using it (e.g. a "this listing only" suggestion approval). */
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  listings ListingAmenity[]

  @@index([isActive])
}

/**
 * Host-submitted "you're missing an option" requests for a property type or amenity
 * not in the current catalog. An admin can edit the label, then approve it either
 * GLOBAL (added to the catalog for all future listings) or LISTING_ONLY (usable just
 * on the listing that requested it, without polluting the catalog for everyone else).
 */
model Suggestion {
  id           String            @id @default(cuid())
  kind         SuggestionKind
  label        String
  note         String?
  status       SuggestionStatus  @default(PENDING)
  scope        SuggestionScope?
  listingId    String?
  hostId       String
  reviewedById String?
  reviewedAt   DateTime?
  adminNote    String?
  createdAt    DateTime          @default(now())

  listing    Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  host       User     @relation("SuggestionHost", fields: [hostId], references: [id])
  reviewedBy User?    @relation("SuggestionReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([hostId])
}

/**
 * A visitor-submitted flag on a listing (e.g. "photos don't match", "price is wrong"),
 * with an optional free-text message. `reporterId` is nullable since reporting doesn't
 * require an account. An admin reviews it from /admin/reports and either dismisses it
 * or removes the listing (suspends it), mirroring Suggestion's review pattern.
 */
model ListingReport {
  id           String       @id @default(cuid())
  listingId    String
  reporterId   String?
  message      String?
  status       ReportStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())

  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporter   User?   @relation("ListingReportReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  reviewedBy User?   @relation("ListingReportReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([listingId])
}

model ListingAmenity {
  listingId String
  amenityId String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([listingId, amenityId])
}

// ─── Pricing ────────────────────────────────────────────────────────────────────

model PricingRule {
  id                String  @id @default(cuid())
  listingId         String  @unique
  baseNightlyRate   Decimal @db.Decimal(10, 2)
  cleaningFee       Decimal @default(0) @db.Decimal(10, 2)
  serviceFeePercent Decimal @default(0) @db.Decimal(5, 2)
  currency          String  @default("EUR")
  minNights         Int     @default(1)
  maxNights         Int     @default(365)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingDatePrice {
  id          String   @id @default(cuid())
  listingId   String
  date        DateTime @db.Date
  nightlyRate Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId])
}

// ─── Availability ───────────────────────────────────────────────────────────────

model AvailabilityBlock {
  id        String    @id @default(cuid())
  listingId String
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  blockType BlockType
  bookingId String?
  reason    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  listing Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([listingId, startDate, endDate])
  @@index([bookingId])
}

// ─── Booking ────────────────────────────────────────────────────────────────────

model Booking {
  id               String        @id @default(cuid())
  listingId        String
  guestId          String
  checkIn          DateTime      @db.Date
  checkOut         DateTime      @db.Date
  guestCount       Int
  nightlyRate      Decimal       @db.Decimal(10, 2)
  cleaningFee      Decimal       @default(0) @db.Decimal(10, 2)
  serviceFee       Decimal       @default(0) @db.Decimal(10, 2)
  totalPrice       Decimal       @db.Decimal(10, 2)
  numberOfNights   Int
  status           BookingStatus @default(PENDING)
  guestNote        String?
  hostNote         String?
  cancellationReason String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  listing            Listing             @relation(fields: [listingId], references: [id])
  guest              User                @relation(fields: [guestId], references: [id])
  availabilityBlocks AvailabilityBlock[]

  @@index([listingId, status])
  @@index([guestId])
  @@index([listingId, checkIn, checkOut])
}

// ─── Settings ───────────────────────────────────────────────────────────────────

model Language {
  code      String   @id // ISO 639-1, e.g. "mk", "en"
  name      String
  isDefault Boolean  @default(false)
  isEnabled Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([isEnabled])
}

// ─── Audit ──────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
}
