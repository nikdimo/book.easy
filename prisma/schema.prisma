generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  STUDIO
  CABIN
  COTTAGE
  LOFT
  OTHER
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  UNPUBLISHED
  SUSPENDED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  CANCELLED_BY_ADMIN
  COMPLETED
}

enum BlockType {
  MANUAL_BLOCK
  BOOKING_HOLD
}

// ─── User & Profile ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          UserRole  @default(USER)
  isHost        Boolean   @default(false)
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile    Profile?
  properties Property[]
  listings   Listing[]
  bookings   Booking[]
  auditLogs  AuditLog[]

  @@index([email])
  @@index([role])
}

model Profile {
  id              String  @id @default(cuid())
  userId          String  @unique
  phone           String?
  bio             String?
  avatarUrl       String?
  hostBio         String?
  hostDisplayName String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Property & Listing ─────────────────────────────────────────────────────────

model Property {
  id           String       @id @default(cuid())
  ownerId      String
  name         String
  propertyType PropertyType
  address      String
  city         String
  area         String?
  country      String       @default("North Macedonia")
  postalCode   String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  owner    User      @relation(fields: [ownerId], references: [id])
  listings Listing[]

  @@index([ownerId])
  @@index([city])
}

model Listing {
  id             String        @id @default(cuid())
  propertyId     String
  hostId         String
  title          String
  slug           String        @unique
  description    String
  status         ListingStatus @default(DRAFT)
  maxGuests      Int
  bedrooms       Int
  bathrooms      Int
  beds           Int
  moderationNote String?
  approvedAt     DateTime?
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  property           Property           @relation(fields: [propertyId], references: [id])
  host               User               @relation(fields: [hostId], references: [id])
  images             ListingImage[]
  amenities          ListingAmenity[]
  pricingRule        PricingRule?
  datePrices         ListingDatePrice[]
  availabilityBlocks AvailabilityBlock[]
  bookings           Booking[]

  @@index([hostId])
  @@index([status])
  @@index([slug])
}

model ListingImage {
  id           String  @id @default(cuid())
  listingId    String
  url          String
  alt          String?
  displayOrder Int     @default(0)
  isPrimary    Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// ─── Amenities ──────────────────────────────────────────────────────────────────

model Amenity {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  icon      String?
  createdAt DateTime @default(now())

  listings ListingAmenity[]
}

model ListingAmenity {
  listingId String
  amenityId String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([listingId, amenityId])
}

// ─── Pricing ────────────────────────────────────────────────────────────────────

model PricingRule {
  id                String  @id @default(cuid())
  listingId         String  @unique
  baseNightlyRate   Decimal @db.Decimal(10, 2)
  cleaningFee       Decimal @default(0) @db.Decimal(10, 2)
  serviceFeePercent Decimal @default(0) @db.Decimal(5, 2)
  currency          String  @default("EUR")
  minNights         Int     @default(1)
  maxNights         Int     @default(365)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingDatePrice {
  id          String   @id @default(cuid())
  listingId   String
  date        DateTime @db.Date
  nightlyRate Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId])
}

// ─── Availability ───────────────────────────────────────────────────────────────

model AvailabilityBlock {
  id        String    @id @default(cuid())
  listingId String
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  blockType BlockType
  bookingId String?
  reason    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  listing Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([listingId, startDate, endDate])
  @@index([bookingId])
}

// ─── Booking ────────────────────────────────────────────────────────────────────

model Booking {
  id               String        @id @default(cuid())
  listingId        String
  guestId          String
  checkIn          DateTime      @db.Date
  checkOut         DateTime      @db.Date
  guestCount       Int
  nightlyRate      Decimal       @db.Decimal(10, 2)
  cleaningFee      Decimal       @default(0) @db.Decimal(10, 2)
  serviceFee       Decimal       @default(0) @db.Decimal(10, 2)
  totalPrice       Decimal       @db.Decimal(10, 2)
  numberOfNights   Int
  status           BookingStatus @default(PENDING)
  guestNote        String?
  hostNote         String?
  cancellationReason String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  listing            Listing             @relation(fields: [listingId], references: [id])
  guest              User                @relation(fields: [guestId], references: [id])
  availabilityBlocks AvailabilityBlock[]

  @@index([listingId, status])
  @@index([guestId])
  @@index([listingId, checkIn, checkOut])
}

// ─── Audit ──────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
}
