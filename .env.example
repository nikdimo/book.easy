# Database — direct Postgres URL (matches docker-compose.yml: user postgres, password postgres, db bookeasy).
# Optional: run `docker compose up -d` if you do not already have Postgres on port 5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bookeasy?schema=public"

# Auth.js — openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: https://book.easy.mk
NEXT_PUBLIC_APP_NAME="book.easy.mk"

# File uploads
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE_MB="10"

# Google OAuth (console.cloud.google.com > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SMTP for magic-link sign-in emails
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="book.easy.mk <hello@book.easy.mk>"

# Claude API (console.anthropic.com) — used to AI-translate fixed UI text for
# languages with useAiTranslation enabled in Admin > Settings > Languages
ANTHROPIC_API_KEY=""
# Pin this in production when upgrading models so translation behavior changes are intentional.
ANTHROPIC_TRANSLATION_MODEL="claude-sonnet-5"
UI_TRANSLATION_SYNC_CONCURRENCY="3"
UI_TRANSLATION_REVIEW_CONCURRENCY="3"
